# Banco de dados
MYSQL_ROOT_PASSWORD=root_secret_change_me
MYSQL_DATABASE=family_quest
MYSQL_USER=fquest_user
MYSQL_PASSWORD=fquest_secret_change_me
DATABASE_URL=mysql+pymysql://fquest_user:fquest_secret_change_me@db:3306/family_quest

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=troque_por_uma_string_aleatoria_longa_de_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY_ID=sua_access_key
R2_SECRET_ACCESS_KEY=sua_secret_key
R2_BUCKET_NAME=family-quest-media
R2_PUBLIC_URL=https://seu-bucket.r2.dev

# Firebase (Push Notifications)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=seu_token_sandbox
MERCADO_PAGO_WEBHOOK_SECRET=seu_webhook_secret

# Ambiente
ENVIRONMENT=development
